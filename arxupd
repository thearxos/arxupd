#!/usr/bin/env bash
ARXOS_VERSION="0.0.1"   # ARXOS: every tool pinned to 0.0.1
case "${1:-}" in --version|-V) echo "arxupd ${ARXOS_VERSION} (ARXOS)"; exit 0 ;; esac
# arxupd - ARXOS self-updater
# Pulls each ARXOS feature repo (tools + cosmetics) from GitHub and runs its
# install.sh, so the system receives updates the moment they're pushed.
# Manifest: /etc/arxos/repos.list   (lines: "name  git-url  [branch]  [type]  [verify]")

# Safety & hardening
set -o nounset
set -o pipefail
: "${TERM:=xterm-256color}"; export TERM   # quiet tput when launched without a terminal (GUI)
export GIT_TERMINAL_PROMPT=0
export GIT_OPTIONAL_LOCKS=0

GB=$'\033[1;38;5;220m'; CB=$'\033[1;38;5;45m'; C=$'\033[38;5;45m'
GR=$'\033[1;32m'; RD=$'\033[1;31m'; DM=$'\033[90m'; BD=$'\033[1m'; RS=$'\033[0m'

MANIFEST="${ARXOS_MANIFEST:-/etc/arxos/repos.list}"
CACHE="${XDG_CACHE_HOME:-$HOME/.cache}/arxos/repos"
mkdir -p -- "$CACHE"

# Default conservative concurrency for network work (fetch/clone/verify). Can be
# overridden by environment: ARXUPD_CONCURRENCY
CONCURRENCY=${ARXUPD_CONCURRENCY:-4}

SPIN=('|' '/' '-' '\\')
LOG=$(mktemp -u -p /tmp arxupd.XXXXXX)
: > "$LOG"
trap 'rm -f "$LOG"; [ -t 1 ] && printf "\033[?25h" 2>/dev/null' EXIT INT TERM

_spin(){ # pid label
  local pid="$1" label="$2" i=0
  if [ ! -t 1 ]; then while kill -0 "$pid" 2>/dev/null; do sleep 0.2; done; return; fi
  printf '\033[?25l'
  while kill -0 "$pid" 2>/dev/null; do
    printf "\r  ${C}%s${RS}  ${DM}%s${RS}\033[K" "${SPIN[i++ % ${#SPIN[@]}]}" "$label"; sleep 0.1
  done
  printf '\r\033[K\033[?25h'
}

# Helper: retry a command (git network ops) up to N tries with exponential backoff
git_retry(){
  local tries=3 delay=1 n=1 rc
  while true; do
    if "$@"; then return 0; fi
    rc=$?
    if [ $n -ge $tries ]; then return $rc; fi
    echo "git: command failed (attempt $n/$tries) — retrying in ${delay}s" >>"$LOG"
    sleep $delay
    delay=$((delay * 2))
    n=$((n + 1))
  done
}

[ -f "$MANIFEST" ] || { printf "  ${RD}xx${RS} no manifest at %s\n" "$MANIFEST"; exit 1; }

printf "\n  ${GB}arx${CB}upd${RS} ${DM}::${RS} ${BD}syncing ARXOS feature repos${RS}\n\n"

# workspace for parallel job logs/status
TMPDIR=$(mktemp -d /tmp/arxupd.jobs.XXXXXX)
trap 'rm -rf "$TMPDIR"' EXIT

# semaphore (named pipe + fd) for concurrency control
mkfifo "$TMPDIR/sem"
exec 3<>"$TMPDIR/sem"
rm -f "$TMPDIR/sem"
for _ in $(seq 1 $CONCURRENCY); do printf '\n' >&3; done

# Arrays to collect install candidates and final statuses
install_list=()
status_file="$TMPDIR/results.txt"
: > "$status_file"

# Counters
n_up=0 n_new=0 n_same=0 n_err=0

# Worker: perform clone/fetch/verify and write status/log
worker(){
  local name="$1" url="$2" branch="$3" type="$4" verify="$5"
  local joblog="$TMPDIR/$name.log"
  local jobstatus="$TMPDIR/$name.status"
  : > "$joblog"

  # basic checks
  if [ -z "$name" ] || [ -z "$url" ]; then
    echo "err|$name|invalid input" >"$jobstatus"
    return
  fi

  dir="$CACHE/$name"
  need_full_fetch=0
  if [ -n "${verify:-}" ]; then need_full_fetch=1; fi

  # clone or fetch
  if [ -d "$dir/.git" ]; then
    before=$(git -C "$dir" rev-parse HEAD 2>/dev/null || true)
    if [ $need_full_fetch -eq 1 ]; then
      git_retry git -C "$dir" fetch -q origin "$branch" >>"$joblog" 2>&1 || true
      git_retry git -C "$dir" fetch -q --tags origin >>"$joblog" 2>&1 || true
      git -C "$dir" reset -q --hard "origin/$branch" >>"$joblog" 2>&1 || true
    else
      git_retry git -C "$dir" fetch -q --depth=1 origin "$branch" >>"$joblog" 2>&1 || true
      git -C "$dir" reset -q --hard "origin/$branch" >>"$joblog" 2>&1 || true
    fi
    after=$(git -C "$dir" rev-parse HEAD 2>/dev/null || true)
    if [ -z "$after" ]; then echo "err|$name|git error" >"$jobstatus"; return; fi
    if [ "$before" = "$after" ]; then echo "same|$name|$after" >"$jobstatus"; return; fi
    echo "upd|$name|$after" >"$jobstatus"; return
  else
    if [ $need_full_fetch -eq 1 ]; then
      git_retry git clone -q -b "$branch" "$url" "$dir" >>"$joblog" 2>&1 || { echo "err|$name|clone failed" >"$jobstatus"; return; }
    else
      git_retry git clone -q --depth=1 -b "$branch" "$url" "$dir" >>"$joblog" 2>&1 || { echo "err|$name|clone failed" >"$jobstatus"; return; }
    fi
    after=$(git -C "$dir" rev-parse HEAD 2>/dev/null || true)
    if [ -z "$after" ]; then echo "err|$name|clone no head" >"$jobstatus"; return; fi
    echo "new|$name|$after" >"$jobstatus"; return
  fi
}

# Read manifest into an array of entries to preserve ordering
mapfile -t manifest_lines < <(sed -n 's/^\s*#.*//; /^\s*$/d; p' "$MANIFEST")

for line in "${manifest_lines[@]}"; do
  # parse fields
  read -r name url branch type verify _ <<< "$line"
  branch="${branch:-main}"
  # sanitize name — skip invalid
  if ! [[ "$name" =~ ^[A-Za-z0-9._-]+$ ]]; then
    printf "  ${RD}xx${RS} %-22s ${RD}%s${RS}\n" "$name" "invalid manifest name (skipped)"
    ((n_err++))
    continue
  fi

  # acquire token (blocks if none available)
  read -u 3 -r _
  {
    worker "$name" "$url" "$branch" "$type" "$verify"
    # release token
    printf '\n' >&3
  } &
done

# wait for all background workers
wait
# close fd
exec 3>&-

# Collect statuses and prepare install candidates
for s in "$TMPDIR"/*.status; do
  [ -e "$s" ] || continue
  IFS='|' read -r st name sha < <(cat "$s")
  case "$st" in
    upd) printf "  ${GR}>>${RS} %-22s ${GR}updated${RS}\n" "$name"; ((n_up++)); install_list+=("$name") ;;
    new) printf "  ${GR}>>${RS} %-22s ${GR}installed${RS}\n" "$name"; ((n_new++)); install_list+=("$name") ;;
    same) printf "  ${DM}..${RS} %-22s ${DM}up to date${RS}\n" "$name"; ((n_same++)); ;;
    err) errmsg=$(sed -n '1p' "$TMPDIR/$name.log" | sed -n '1p'); printf "  ${RD}xx${RS} %-22s ${RD}%s${RS}\n" "$name" "${errmsg:-failed}"; ((n_err++)); ;;
    *) printf "  ${RD}xx${RS} %-22s ${RD}%s${RS}\n" "$name" "unknown status"; ((n_err++)); ;;
  esac
done

# Run installers serially (safe mode) — only for install candidates
for name in "${install_list[@]}"; do
  dir="$CACHE/$name"
  if [ -f "$dir/install.sh" ]; then
    printf "  ${DM}::${RS} running install for %s\n" "$name"
    # Run installer in a tightly-scoped environment to avoid leaking host env
    if ! ( cd "$dir" && env -i PATH=/usr/bin:/bin HOME="$dir" GIT_TERMINAL_PROMPT=0 bash --noprofile --norc "./install.sh" ) >"$TMPDIR/$name.install.log" 2>&1; then
      printf "  ${RD}xx${RS} %-22s ${RD}%s${RS}\n" "$name" "install failed"
      ((n_err++))
    fi
  fi
done

printf "\n  ${DM}%s updated · %s installed · %s current · %s failed${RS}\n\n" "$n_up" "$n_new" "$n_same" "$n_err"
[ "$n_err" -eq 0 ]
